# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Group/Channel ID where questions are posted (negative number for groups)
# e.g. -1001234567890
GROUP_ID=-1001234567890

# Your personal Telegram user ID (for admin commands + low-stock alerts)
ADMIN_ID=123456789

# ── Database ──────────────────────────────────────────────────────────────────
# On Railway: use ${{Postgres.DATABASE_URL}}
# Locally: create a Postgres DB and paste the URL here
DATABASE_URL=postgresql://user:password@localhost:5432/hells_solyanka

# ── Scraper ───────────────────────────────────────────────────────────────────
# ID of the FIRST pack to scrape (Балканфест-2025 = 6705)
# Change to any other pack ID if needed.
PACK_ID=6705
